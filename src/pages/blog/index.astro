---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import { SITE_DESCRIPTION } from '../../consts';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

const categories = [
	{ slug: 'seo-local', label: 'SEO Local', icon: '📍' },
	{ slug: 'sites', label: 'Sites que Convertem', icon: '💻' },
	{ slug: 'trafego', label: 'Tráfego Pago', icon: '📈' },
	{ slug: 'diagnostico', label: 'Diagnóstico', icon: '🔍' },
];
---

<!doctype html>
<html lang="pt-BR">
	<head>
		<BaseHead title="Blog — Operaio" description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />

		<div class="blog-hero">
			<div class="blog-hero-inner">
				<span class="section-label">● TODOS OS ARTIGOS</span>
				<h1>Blog Operaio</h1>
				<p>Conteúdo prático sobre SEO local, sites que convertem e tráfego pago para negócios locais no interior de Goiás.</p>
			</div>
		</div>

		<!-- Category filter strip -->
		<div class="cat-strip">
			<div class="cat-strip-inner">
				<a href="/blog" class="cat-pill active">Todos</a>
				{categories.map(cat => (
					<a href={`/blog#${cat.slug}`} class="cat-pill">
						<span>{cat.icon}</span>
						{cat.label}
					</a>
				))}
			</div>
		</div>

		<main>
			{posts.length === 0 ? (
				<div class="empty-state">
					<p>Primeiros artigos chegando em breve. Volte logo!</p>
				</div>
			) : (
				<div class="posts-grid">
					{posts.map((post) => (
						<a href={`/blog/${post.id}/`} class="post-card card">
							{post.data.heroImage && (
								<div class="post-img">
									<img
										src={post.data.heroImage}
										alt={post.data.title}
										width={720}
										height={360}
										loading="lazy"
									/>
								</div>
							)}
							<div class="post-body">
								<span class="cat-badge">● Artigo</span>
								<h2 class="post-title">{post.data.title}</h2>
								<p class="post-desc">{post.data.description}</p>
								<div class="post-meta">
									<FormattedDate date={post.data.pubDate} />
									<span class="read-cta">Ler →</span>
								</div>
							</div>
						</a>
					))}
				</div>
			)}
		</main>

		<Footer />
	</body>
</html>

<style>
	.blog-hero {
		border-bottom: 1px solid var(--border);
		padding: 3.5rem 1.5rem 3rem;
		background: linear-gradient(160deg, #0f1923 60%, #16232e 100%);
	}
	.blog-hero-inner {
		max-width: 700px;
		margin: 0 auto;
	}
	.section-label {
		display: block;
		font-size: 0.75rem;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.1em;
		color: var(--accent);
		margin-bottom: 1rem;
	}
	.blog-hero h1 {
		font-size: 2.5rem;
		color: var(--white);
		margin-bottom: 0.75rem;
		letter-spacing: -0.03em;
	}
	.blog-hero p {
		color: var(--text-muted);
		font-size: 1rem;
		line-height: 1.65;
		margin: 0;
	}

	/* Category strip */
	.cat-strip {
		border-bottom: 1px solid var(--border);
		background: var(--bg-card);
	}
	.cat-strip-inner {
		max-width: 1200px;
		margin: 0 auto;
		padding: 0 1.5rem;
		display: flex;
		gap: 0.25rem;
		overflow-x: auto;
		scrollbar-width: none;
	}
	.cat-strip-inner::-webkit-scrollbar { display: none; }
	.cat-pill {
		display: inline-flex;
		align-items: center;
		gap: 0.4rem;
		white-space: nowrap;
		padding: 0.85rem 1rem;
		font-size: 0.85rem;
		font-weight: 500;
		color: var(--text-muted);
		text-decoration: none;
		border-bottom: 2px solid transparent;
		transition: color 0.15s, border-color 0.15s;
	}
	.cat-pill:hover, .cat-pill.active {
		color: var(--white);
		border-bottom-color: var(--accent);
	}

	/* Posts grid */
	main {
		max-width: 1200px;
		margin: 0 auto;
		padding: 2.5rem 1.5rem 4rem;
	}
	.posts-grid {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 1.5rem;
	}
	.post-card {
		display: flex;
		flex-direction: column;
		text-decoration: none;
		color: inherit;
	}
	.post-img {
		height: 200px;
		overflow: hidden;
	}
	.post-img img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		border-radius: 12px 12px 0 0;
		transition: transform 0.3s ease;
	}
	.post-card:hover .post-img img {
		transform: scale(1.04);
	}
	.post-body {
		padding: 1.25rem;
		flex: 1;
		display: flex;
		flex-direction: column;
	}
	.post-title {
		font-size: 1.05rem;
		font-weight: 700;
		color: var(--white);
		margin: 0.4rem 0 0.6rem;
		line-height: 1.35;
	}
	.post-desc {
		font-size: 0.875rem;
		color: var(--text-muted);
		line-height: 1.55;
		flex: 1;
		margin-bottom: 1rem;
	}
	.post-meta {
		display: flex;
		align-items: center;
		justify-content: space-between;
		font-size: 0.8rem;
		color: var(--text-faint);
	}
	.read-cta {
		font-weight: 600;
		color: var(--accent);
	}

	.empty-state {
		text-align: center;
		padding: 5rem 2rem;
		color: var(--text-muted);
	}

	@media (max-width: 900px) {
		.posts-grid { grid-template-columns: repeat(2, 1fr); }
	}
	@media (max-width: 560px) {
		.posts-grid { grid-template-columns: 1fr; }
	}
</style>
