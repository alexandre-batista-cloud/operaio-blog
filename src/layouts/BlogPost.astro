---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';

type Props = CollectionEntry<'blog'>['data'];

const { title, description, pubDate, updatedDate, heroImage } = Astro.props;
---

<html lang="pt-BR">
	<head>
		<BaseHead title={`${title} | Operaio Blog`} description={description} />
	</head>

	<body>
		<Header />

		<main class="article-main">
			<article>
				<!-- Breadcrumb (Kantar pattern) -->
				<nav class="breadcrumb" aria-label="Navegação">
					<a href="/blog">← Voltar para o Blog</a>
				</nav>

				<!-- H1 FIRST (Kantar: título antes da imagem) -->
				<div class="article-header">
					<div class="article-meta-top">
						<span class="cat-badge">● ARTIGO</span>
					</div>
					<h1 class="article-title">{title}</h1>
					<p class="article-desc">{description}</p>

					<div class="article-meta">
						<FormattedDate date={pubDate} />
						{updatedDate && (
							<span class="updated">· Atualizado em <FormattedDate date={updatedDate} /></span>
						)}
						<div class="share-links">
							<a href={`https://twitter.com/intent/tweet?text=${encodeURIComponent(title)}&url=${Astro.url}`} target="_blank" rel="noopener" aria-label="Compartilhar no X" title="Compartilhar no X">
								<svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
									<path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.736l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
								</svg>
							</a>
							<a href={`https://www.linkedin.com/sharing/share-offsite/?url=${Astro.url}`} target="_blank" rel="noopener" aria-label="Compartilhar no LinkedIn" title="Compartilhar no LinkedIn">
								<svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
									<path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
								</svg>
							</a>
						</div>
					</div>
				</div>

				<!-- Author box BEFORE body (Kantar pattern) -->
				<div class="author-box">
					<div class="author-avatar">A</div>
					<div class="author-info">
						<span class="author-name">Alexandre Batista</span>
						<span class="author-role">Fundador · Operaio — Sistema Digital para Negócios Locais</span>
					</div>
				</div>

				<!-- Hero image AFTER H1 (Kantar pattern) -->
				{heroImage && (
					<div class="hero-image">
						<Image
							width={1020}
							height={510}
							src={heroImage}
							alt={`Imagem: ${title}`}
							loading="eager"
						/>
					</div>
				)}

				<!-- Article body -->
				<div class="prose">
					<slot />
				</div>

				<!-- End CTA (Kantar: subtle, not screaming) -->
				<div class="article-cta">
					<div class="article-cta-inner">
						<p>
							<strong>Gostou do conteúdo?</strong> A Operaio ajuda negócios locais a vender mais com menos atrito digital.
						</p>
						<a href="https://operaio.com.br/#diagnostico" class="btn-primary" target="_blank" rel="noopener">
							Diagnóstico gratuito em 30 min →
						</a>
					</div>
				</div>

				<!-- Back link -->
				<div class="back-link">
					<a href="/blog">← Ver todos os artigos</a>
				</div>
			</article>
		</main>

		<Footer />
	</body>
</html>

<style>
	.article-main {
		max-width: 780px;
		margin: 0 auto;
		padding: 2rem 1.5rem 4rem;
	}

	/* Breadcrumb */
	.breadcrumb {
		margin-bottom: 2rem;
	}
	.breadcrumb a {
		font-size: 0.875rem;
		font-weight: 500;
		color: var(--text-muted);
		text-decoration: none;
		transition: color 0.15s;
	}
	.breadcrumb a:hover { color: var(--text); }

	/* Article header */
	.article-header {
		margin-bottom: 1.75rem;
	}
	.article-meta-top {
		margin-bottom: 0.75rem;
	}
	.article-title {
		font-size: clamp(1.75rem, 4vw, 2.75rem);
		font-weight: 800;
		line-height: 1.15;
		color: var(--white);
		margin-bottom: 1rem;
		letter-spacing: -0.02em;
	}
	.article-desc {
		font-size: 1.1rem;
		color: var(--text-muted);
		line-height: 1.65;
		margin-bottom: 1.25rem;
	}
	.article-meta {
		display: flex;
		align-items: center;
		gap: 0.5rem;
		font-size: 0.875rem;
		color: var(--text-faint);
		flex-wrap: wrap;
	}
	.updated {
		font-style: italic;
	}
	.share-links {
		display: flex;
		gap: 0.5rem;
		margin-left: auto;
	}
	.share-links a {
		display: flex;
		align-items: center;
		justify-content: center;
		width: 30px;
		height: 30px;
		border-radius: 6px;
		background: var(--bg-card);
		border: 1px solid var(--border);
		color: var(--text-muted);
		text-decoration: none;
		transition: color 0.15s, border-color 0.15s;
	}
	.share-links a:hover {
		color: var(--accent);
		border-color: var(--tag-border);
	}

	/* Author box */
	.author-box {
		display: flex;
		align-items: center;
		gap: 0.9rem;
		padding: 1rem 1.25rem;
		background: var(--bg-card);
		border: 1px solid var(--border);
		border-radius: 10px;
		margin-bottom: 2rem;
	}
	.author-avatar {
		width: 40px;
		height: 40px;
		border-radius: 50%;
		background: var(--accent);
		display: flex;
		align-items: center;
		justify-content: center;
		font-weight: 700;
		font-size: 1rem;
		color: #fff;
		flex-shrink: 0;
	}
	.author-info {
		display: flex;
		flex-direction: column;
		gap: 0.1rem;
	}
	.author-name {
		font-size: 0.9rem;
		font-weight: 700;
		color: var(--white);
	}
	.author-role {
		font-size: 0.8rem;
		color: var(--text-muted);
	}

	/* Hero image */
	.hero-image {
		margin-bottom: 2.5rem;
		border-radius: 12px;
		overflow: hidden;
	}
	.hero-image img {
		width: 100%;
		height: auto;
		border-radius: 12px;
		display: block;
	}

	/* Prose (body) */
	.prose {
		font-size: 1.05rem;
		line-height: 1.8;
		color: var(--text);
	}

	/* Article end CTA */
	.article-cta {
		margin: 3.5rem 0 2rem;
		border-top: 1px solid var(--border);
		padding-top: 2.5rem;
	}
	.article-cta-inner {
		background: linear-gradient(135deg, #16232e, #1c2e3d);
		border: 1px solid rgba(240,90,40,0.2);
		border-radius: 12px;
		padding: 2rem;
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1.5rem;
		flex-wrap: wrap;
	}
	.article-cta-inner p {
		margin: 0;
		font-size: 0.95rem;
		color: var(--text-muted);
		flex: 1;
		min-width: 220px;
	}
	.article-cta-inner strong { color: var(--white); }

	/* Back link */
	.back-link {
		margin-top: 2rem;
	}
	.back-link a {
		font-size: 0.875rem;
		font-weight: 500;
		color: var(--text-muted);
		text-decoration: none;
	}
	.back-link a:hover { color: var(--text); }

	@media (max-width: 600px) {
		.article-cta-inner {
			flex-direction: column;
			align-items: flex-start;
		}
	}
</style>
